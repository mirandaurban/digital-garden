---
import { SECCIONES, type SeccionId } from '../lib/secciones';

interface Pieza {
  seccionId: SeccionId;
  title: string;
  href: string;
}
interface Props {
  piezas: Pieza[];
}
const { piezas } = Astro.props;
---
<div class="mosaico" role="list">
  {piezas.map((p) => {
    const s = SECCIONES[p.seccionId];
    return (
      <a role="listitem" href={p.href} class="mosaico__pieza" style={`--accent: var(--${s.accent}); --accent-soft: var(--${s.accent}-soft)`}>
        <span class="mosaico__glifo" aria-hidden="true">{s.glifo}</span>
        <span class="mosaico__label">
          <span class="mosaico__eyebrow">{s.label}</span>
          {p.title}
        </span>
      </a>
    );
  })}
</div>

<style>
  .mosaico {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(64px, 1fr));
    gap: var(--space-2);
  }
  .mosaico__pieza {
    position: relative;
    aspect-ratio: 1;
    border-radius: var(--radius-sm);
    background: var(--accent-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: transform var(--transition);
  }
  .mosaico__pieza:hover,
  .mosaico__pieza:focus-visible {
    transform: scale(1.06);
    z-index: 2;
  }
  .mosaico__glifo {
    font-size: 1.1rem;
    color: var(--accent);
    transition: opacity var(--transition);
  }
  .mosaico__pieza:hover .mosaico__glifo,
  .mosaico__pieza:focus-visible .mosaico__glifo {
    opacity: 0;
  }
  .mosaico__label {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-2);
    background: var(--accent);
    color: var(--bg-elevated);
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 600;
    line-height: 1.25;
    opacity: 0;
    transform: scale(0.92);
    transition: opacity var(--transition), transform var(--transition);
  }
  .mosaico__eyebrow {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.85;
    margin-bottom: 2px;
  }
  .mosaico__pieza:hover .mosaico__label,
  .mosaico__pieza:focus-visible .mosaico__label {
    opacity: 1;
    transform: scale(1);
  }
</style>
